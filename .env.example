# ═══════════════════════════════════════════════
# TaxPilot AI — Environment Variables
# ═══════════════════════════════════════════════

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/taxpilot
DATABASE_ECHO=false

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── LLM (Groq — free tier) ──
GROQ_API_KEY=gsk_your_api_key_here

# ── GST Portal (via GSP) ──
GST_GSP_CLIENT_ID=
GST_GSP_CLIENT_SECRET=
GST_SANDBOX=true

# ── Income Tax Portal ──
IT_PORTAL_CLIENT_ID=
IT_PORTAL_CLIENT_SECRET=

# ── TRACES (TDS) ──
TRACES_USER=
TRACES_PASSWORD=

# ── Tally ERP ──
TALLY_HOST=localhost
TALLY_PORT=9000

# ── Zoho Books ──
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=

# ── Auth ──
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── App ──
ENVIRONMENT=development
LOG_LEVEL=INFO
UPLOAD_DIR=./data/uploads
